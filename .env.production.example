# Fleet Feast - Production Environment Variables

# Database
DATABASE_URL=postgresql://user:password@host:5432/fleetfeast_prod

# Authentication
NEXTAUTH_URL=https://fleetfeast.com
NEXTAUTH_SECRET=your-production-secret-key-minimum-32-chars

# Helcim Payment Integration (Production)
HELCIM_API_TOKEN=your_helcim_api_token
HELCIM_ACCOUNT_ID=your_helcim_account_id
HELCIM_TERMINAL_ID=your_helcim_terminal_id
HELCIM_WEBHOOK_SECRET=your_helcim_webhook_secret
NEXT_PUBLIC_HELCIM_JS_CONFIG_TOKEN=your_helcim_js_config_token

# Encryption for sensitive data (bank accounts)
ENCRYPTION_KEY=your-encryption-key-minimum-32-chars-long
ENCRYPTION_SALT=your-encryption-salt-optional

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=fleetfeast-production

# Email (SendGrid)
SENDGRID_API_KEY=SG.your_production_key
SENDGRID_FROM_EMAIL=noreply@fleetfeast.com

# Redis (Caching) - Optional
REDIS_URL=redis://user:password@host:6379

# Monitoring - Optional
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
MAINTENANCE_MODE=false

# Environment
NODE_ENV=production
