# ==============================================================================
# FLEET FEAST ENVIRONMENT VARIABLES
# ==============================================================================
# This file contains ALL environment variables required for Fleet Feast.
# Copy this to .env.local for local development.
# Add production values to Vercel environment variables.
#
# SECURITY: Never commit .env.local to version control!
# ==============================================================================

# ==============================================================================
# DATABASE (PostgreSQL 15+)
# ==============================================================================
# Railway (Development/MVP): postgresql://postgres:password@containers-us-west-123.railway.app:5432/railway
# AWS RDS (Production): postgresql://admin:password@fleet-feast-production.c9aklu4k6c7w.us-east-1.rds.amazonaws.com:5432/fleet_feast
# Local: postgresql://postgres:password@localhost:5432/fleet_feast_dev
#
# IMPORTANT: Add ?schema=public&connection_limit=20 for production
DATABASE_URL="postgresql://user:password@localhost:5432/fleet_feast?schema=public"

# ==============================================================================
# REDIS CACHE (Redis 7+)
# ==============================================================================
# Option 1: Upstash (Recommended for MVP - serverless, free tier)
UPSTASH_REDIS_REST_URL="https://us1-desired-swan-12345.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AbCdEfGhIjKlMnOpQrStUvWxYz1234567890..."

# Option 2: Native Redis (AWS ElastiCache or local)
REDIS_URL="redis://localhost:6379"

# Note: For production, use Upstash REST API for serverless compatibility

# ==============================================================================
# AUTHENTICATION (NextAuth.js v5)
# ==============================================================================
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Production: Update NEXTAUTH_URL to https://fleetfeast.com
# Preview: Vercel automatically sets NEXTAUTH_URL for preview deployments

# ==============================================================================
# DATA ENCRYPTION
# ==============================================================================
# AES-256 encryption key for sensitive data (bank accounts, etc.)
# Generate: openssl rand -base64 32
# CRITICAL: Keep this secret secure and NEVER commit to version control
# In production, store in Vercel environment variables (encrypted at rest)
ENCRYPTION_KEY="your-encryption-key-here-generate-with-openssl-rand-base64-32"

# Optional: Custom salt for key derivation (defaults to built-in salt)
# Generate: openssl rand -hex 64
ENCRYPTION_SALT="your-encryption-salt-here-optional"

# ==============================================================================
# PAYMENT PROCESSING (Helcim)
# ==============================================================================
# Helcim Dashboard: https://app.helcim.com
# Get credentials from: Settings → API Access → API Tokens
#
# IMPORTANT: Helcim does not have an npm SDK - we use the REST API directly
# Use HelcimPay.js on the frontend for secure card tokenization
#
# API Documentation: https://devdocs.helcim.com/

# API token (required for all API requests)
HELCIM_API_TOKEN="your_api_token_here"

# Account ID (found in Helcim dashboard under Settings → Business Info)
HELCIM_ACCOUNT_ID="your_account_id_here"

# Terminal ID (found in Helcim dashboard under Settings → Payment Terminals)
HELCIM_TERMINAL_ID="your_terminal_id_here"

# JS config token (for HelcimPay.js frontend integration)
# Get from: Settings → HelcimPay.js → Configuration
HELCIM_JS_CONFIG_TOKEN="your_js_config_token_here"

# Webhook secret (for verifying webhook signatures)
# Get from: Settings → Webhooks → Create Webhook
# Generate: openssl rand -hex 32
HELCIM_WEBHOOK_SECRET="your_webhook_secret_here"

# ==============================================================================
# EMAIL DELIVERY
# ==============================================================================
# Option 1: SendGrid (Recommended for MVP - 100 emails/day free)
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@fleetfeast.com"
SENDGRID_FROM_NAME="Fleet Feast"

# Option 2: AWS SES (Production - requires verified domain)
# AWS_SES_REGION="us-east-1"
# AWS_SES_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SES_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# AWS_SES_FROM_EMAIL="noreply@fleetfeast.com"

# ==============================================================================
# FILE STORAGE (AWS S3)
# ==============================================================================
# AWS IAM User credentials with S3 access
# Create user: IAM → Users → Create User → Attach policy: AmazonS3FullAccess (or custom)
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_S3_BUCKET="fleet-feast-production"
AWS_S3_REGION="us-east-1"

# CloudFront CDN (Optional - for faster global delivery)
# AWS_CLOUDFRONT_DOMAIN="d1234567890abc.cloudfront.net"

# Alternative: Cloudinary (built-in image optimization)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="123456789012345"
# CLOUDINARY_API_SECRET="abcdefghijklmnopqrstuvwxyz123456"

# ==============================================================================
# GOOGLE MAPS API
# ==============================================================================
# Google Cloud Console → APIs & Services → Credentials → Create API Key
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Restrict API key to your domain in production (https://fleetfeast.com/*)

# ==============================================================================
# MONITORING & ERROR TRACKING
# ==============================================================================
# Sentry.io (Recommended for production)
# Create project: sentry.io → Create Project → Next.js
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENTRY_ORG="fleet-feast"
SENTRY_PROJECT="fleet-feast-production"

# Environment for Sentry (development, preview, production)
SENTRY_ENVIRONMENT="development"

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
# Public-facing URL (used for emails, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: https://fleetfeast.com
# Preview: https://fleet-feast-git-feature-branch.vercel.app

# Node environment (development, test, production)
NODE_ENV="development"

# ==============================================================================
# PLATFORM BUSINESS LOGIC
# ==============================================================================
# Platform commission (percentage, 0-100)
PLATFORM_FEE_PERCENTAGE=15

# Escrow hold period (days) before releasing payment to vendor
ESCROW_HOLD_DAYS=7

# Maximum file upload size (MB)
MAX_FILE_SIZE_MB=10

# Minimum booking amount (USD)
MIN_BOOKING_AMOUNT=100

# Maximum advance booking period (days)
MAX_ADVANCE_BOOKING_DAYS=365

# ==============================================================================
# CRON JOB AUTHENTICATION
# ==============================================================================
# Secret token for authenticating Vercel cron jobs
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here-generate-with-openssl-rand-base64-32"

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable real-time messaging (WebSocket or polling)
ENABLE_REAL_TIME_MESSAGING=false

# Enable mobile app API endpoints
ENABLE_MOBILE_APP_API=false

# Enable vendor analytics dashboard
ENABLE_VENDOR_ANALYTICS=false

# Enable admin approval queue
ENABLE_VENDOR_APPROVAL_QUEUE=true

# Enable automatic payment release (vs manual)
ENABLE_AUTO_PAYMENT_RELEASE=true

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Requests per minute for different endpoints
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_SEARCH=50

# ==============================================================================
# LOGGING
# ==============================================================================
# Log level (debug, info, warn, error)
LOG_LEVEL="info"

# Enable query logging in development (Prisma)
ENABLE_QUERY_LOGGING=true

# ==============================================================================
# TESTING (Optional)
# ==============================================================================
# Separate database for integration tests
DATABASE_URL_TEST="postgresql://postgres:password@localhost:5432/fleet_feast_test?schema=public"
